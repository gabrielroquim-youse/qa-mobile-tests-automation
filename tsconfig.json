{
  "compilerOptions": {
    "target": "ES2021",
    "lib": ["ES2021"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "types": ["node", "mocha", "@wdio/globals/types"]
  },
  "include": ["tests/**/*", "config/**/*", "scripts/**/*", "wdio.conf.ts"],
  "exclude": ["dist", "node_modules", "allure-results", "allure-report", "logs"]
}
