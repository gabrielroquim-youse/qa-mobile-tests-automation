# Ambiente
ENV=qa

# Plataforma: android | ios | both (padrão: android)
PLATFORM=android

# ── Android ──────────────────────────────────────────────────────────────────
ANDROID_APP_PATH=./apps/youse-qa.apk
ANDROID_APP_PACKAGE=br.com.youse.debug
ANDROID_APP_ACTIVITY=br.com.youse.MainActivity
# true = usa app já instalado no celular/emulador (sem APK local)
ANDROID_USE_INSTALLED_APP=false
ANDROID_DEVICE_NAME=Android Emulator
# Versão REAL do aparelho (adb shell getprop ro.build.version.release)
# Samsung S22: 14–16 | LG K415S/K41S: 9–11 (não use a versão de outro celular)
ANDROID_PLATFORM_VERSION=14
# Serial USB (adb devices) — use ao alternar entre aparelhos
ANDROID_UDID=

# Desbloqueio automático (opcional — se o celular tiver PIN/senha/pattern)
# ANDROID_UNLOCK_TYPE=pin
# ANDROID_UNLOCK_KEY=1234
# Manter tela ligada via adb durante testes (padrão: true; defina false para desligar)
ANDROID_KEEP_AWAKE=true

# ── iOS ──────────────────────────────────────────────────────────────────────
IOS_APP_PATH=./apps/youse-qa.app
IOS_BUNDLE_ID=io.youse.app
IOS_DEVICE_NAME=iPhone 15
IOS_PLATFORM_VERSION=17.0
IOS_UDID=

# ── Appium Server ────────────────────────────────────────────────────────────
APPIUM_HOST=127.0.0.1
APPIUM_PORT=4723

# ── Credenciais e massa de teste ─────────────────────────────────────────────
TEST_NAME=John Youser
TEST_DOCUMENT_NUMBER=123.456.761-08
TEST_EMAIL=automation@youse.com.br
TEST_USER_TEL=(11) 91234-5678
TEST_LICENSE_PLATE=YOU-0020

# ── Timeouts (ms) ────────────────────────────────────────────────────────────
TIMEOUT=60000
IMPLICIT_WAIT=10000
